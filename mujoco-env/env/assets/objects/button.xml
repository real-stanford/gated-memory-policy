<!-- Adapted from
https://github.com/real-stanford/scalingup/blob/master/scalingup/environment/mujoco/assets/custom/catapult/catapult.xml -->

<mujoco model="button">
    <compiler angle="radian" autolimits="true" />

    <default>
        <default class="visual">
            <geom contype="0" conaffinity="0" group="2" />
        </default>
        <default class="collision">
            <geom group="3" condim="3" friction="0.99" priority="1" />
        </default>
    </default>
    <asset>
        <material name="material_0" rgba="0.1 0.2 0.1 1" specular="0.0" shininess="0.0" />
        <material name="material_1" rgba="1.0 0.2 0.2 1" specular="0.0" shininess="0.0" />
        <material name="material_2" rgba="0.2 0.3 0.2 1" specular="0.0" shininess="0.0" />
    </asset>
    <worldbody>
        <body name="button">
            <geom type="box" size="0.03 0.03 0.015" pos="0.0 0.0 0" class="collision" />
            <geom type="box" size="0.03 0.03 0.015" pos="0.0 0.0 0" class="visual"
                material="material_0" />

            <body name="button_slider" pos="0.0 0.0 0.015">
                <joint name="button_slider" type="slide" range="0 0.02" axis="0 0 -1"
                    damping="0.01"
                    springref="0" stiffness="0.05" />
                <geom type="capsule" size="0.015 0.006" class="collision" mass="0.00001" />
                <geom type="cylinder" size="0.015 0.02" class="visual" mass="0.0"
                    material="material_1" />
                <camera name="button_side_view" pos="-0.08 0.08 0.08" euler="-0.8 -0.6 0" />
            </body>

        </body>
    </worldbody>
    <contact>
        <exclude body1="button" body2="button_slider" />
    </contact>
    <equality>
        <weld name="button_slider" body1="button_slider" relpose="0 5 0 0 0 0 0" torquescale="100" />
    </equality>
</mujoco>
    